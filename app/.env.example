# NextAuth — Google OAuth wired through NextAuth v5.
# `NEXTAUTH_SECRET` must byte-match the value the FastAPI backend uses to
# verify JWTs (backend/app/core/auth.py). A mismatch produces silent 401s.
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Google OAuth credentials (Google Cloud Console → APIs & Services → Credentials).
# Authorized redirect URI: ${NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Public API base URL — exposed to the browser by Next.js.
# MUST include the /api/v1 prefix: the FastAPI backend mounts every router
# under settings.api_v1_prefix (backend/app/config.py, main.py:223-239) and
# the psx-ui wrappers call paths like /strategies, /signals (lib/api/*.ts).
# Local dev: http://127.0.0.1:8000/api/v1   |   Prod: https://<railway-app>/api/v1
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000/api/v1
